<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\FrameXML\UI.xsd">
    <Frame name="DMoneyFrameTemplate" virtual="true">
        <Size>
            <AbsDimension x="192" y="28"/>
        </Size>
        <Frames>
            <Button name="$parentCopperButton">
                <Size>
                    <AbsDimension x="47" y="19"/>
                </Size>
                <Anchors>
                    <Anchor point="RIGHT">
                        <Offset>
                            <AbsDimension x="-13" y="0"/>
                        </Offset>
                    </Anchor>
                </Anchors>
                <Scripts>
                    <OnClick>
						local parent = this:GetParent();
						OpenCoinPickupFrame(1, DMoneyTypeInfo[parent.moneyType].UpdateFunc(), parent);
						parent.hasPickup = 1;
					</OnClick>
                </Scripts>
                <NormalTexture file="Interface\AddOns\DialogUI\src\assets\art\icons\Coin-Copper">
                    <Size>
                        <AbsDimension x="19" y="19"/>
                    </Size>
                    <Anchors>
                        <Anchor point="RIGHT"/>
                    </Anchors>
                </NormalTexture>
                <ButtonText name="$parentText" inherits="DMoneyFont" justifyH="RIGHT">
                    <Anchors>
                        <Anchor point="RIGHT">
                            <Offset>
                                <AbsDimension x="-23" y="0"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                </ButtonText>
                <NormalFont inherits="DMoneyFont" justifyH="RIGHT"/>
                <PushedTextOffset>
                    <AbsDimension x="0" y="0"/>
                </PushedTextOffset>
            </Button>
            <Button name="$parentSilverButton">
                <Size>
                    <AbsDimension x="47" y="19"/>
                </Size>
                <Anchors>
                    <Anchor point="RIGHT" relativeTo="$parentCopperButton" relativePoint="LEFT">
                        <Offset>
                            <AbsDimension x="-4" y="0"/>
                        </Offset>
                    </Anchor>
                </Anchors>
                <Scripts>
                    <OnClick>
						local parent = this:GetParent();
						OpenCoinPickupFrame(COPPER_PER_SILVER, DMoneyTypeInfo[parent.moneyType].UpdateFunc(), parent);
						parent.hasPickup = 1;
					</OnClick>
                </Scripts>
                <NormalTexture file="Interface\AddOns\DialogUI\src\assets\art\icons\Coin-Silver">
                    <Size>
                        <AbsDimension x="19" y="19"/>
                    </Size>
                    <Anchors>
                        <Anchor point="RIGHT"/>
                    </Anchors>
                </NormalTexture>
                <ButtonText name="$parentText" inherits="DMoneyFont" justifyH="RIGHT">
                    <Anchors>
                        <Anchor point="RIGHT">
                            <Offset>
                                <AbsDimension x="-23" y="0"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                </ButtonText>
                <NormalFont inherits="DMoneyFont" justifyH="RIGHT"/>
                <PushedTextOffset>
                    <AbsDimension x="0" y="0"/>
                </PushedTextOffset>
            </Button>
            <Button name="$parentGoldButton">
                <Size>
                    <AbsDimension x="47" y="19"/>
                </Size>
                <Anchors>
                    <Anchor point="RIGHT" relativeTo="$parentSilverButton" relativePoint="LEFT">
                        <Offset>
                            <AbsDimension x="-4" y="0"/>
                        </Offset>
                    </Anchor>
                </Anchors>
                <Scripts>
                    <OnClick>
						local parent = this:GetParent();
						OpenCoinPickupFrame(COPPER_PER_GOLD, DMoneyTypeInfo[parent.moneyType].UpdateFunc(), parent);
						parent.hasPickup = 1;
					</OnClick>
                </Scripts>
                <NormalTexture file="Interface\AddOns\DialogUI\src\assets\art\icons\Coin-Gold">
                    <Size>
                        <AbsDimension x="19" y="19"/>
                    </Size>
                    <Anchors>
                        <Anchor point="RIGHT"/>
                    </Anchors>
                </NormalTexture>
                <ButtonText name="$parentText" inherits="DMoneyFont" justifyH="RIGHT">
                    <Anchors>
                        <Anchor point="RIGHT">
                            <Offset>
                                <AbsDimension x="-23" y="0"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                </ButtonText>
                <NormalFont inherits="DMoneyFont" justifyH="RIGHT"/>
                <PushedTextOffset>
                    <AbsDimension x="0" y="0"/>
                </PushedTextOffset>
            </Button>
        </Frames>
        <Scripts>
            <OnLoad>
				DMoneyFrame_OnLoad();
			</OnLoad>
            <OnEvent>
				DMoneyFrame_OnEvent();
			</OnEvent>
            <OnShow>
				DMoneyFrame_UpdateMoney();
			</OnShow>
            <OnHide>
				if ( this.hasPickup == 1 ) then
					CoinPickupFrame:Hide();
					this.hasPickup = 0;
				end
			</OnHide>
        </Scripts>
    </Frame>
</Ui>